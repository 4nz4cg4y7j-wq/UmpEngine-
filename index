<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Officials Engine | Smart Sports Officiating Software</title>
  <style>
    :root {
      --bg: #020913;
      --panel: #061a2d;
      --line: rgba(134,188,255,0.32);
      --text: #f7fbff;
      --muted: #d9e6f7;
      --blue: #2478ff;
      --blue-2: #0f58d9;
      --green: #57d980;
      --violet: #9663ff;
      --shadow: 0 24px 80px rgba(0,0,0,0.44);
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: Inter, system-ui, Arial, sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at 18% 0%, rgba(36,120,255,0.22), transparent 38rem),
        radial-gradient(circle at 88% 12%, rgba(150,99,255,0.16), transparent 32rem),
        var(--bg);
      min-height: 100vh;
    }
    a { color: inherit; text-decoration: none; }
    img { display: block; max-width: 100%; }

    /* ── HEADER ── */
    header {
      border-bottom: 1px solid rgba(100,164,255,0.12);
      background: rgba(2,9,19,0.92);
      backdrop-filter: blur(10px);
      position: sticky; top: 0; z-index: 10;
    }
    .nav {
      width: min(100% - 40px, 1220px);
      margin: auto;
      min-height: 72px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 22px;
    }
    .logo { font-size: 1.3rem; font-weight: 900; letter-spacing: 1px; text-transform: uppercase; }
    .logo span { color: var(--blue); }
    .nav-links {
      display: flex;
      align-items: center;
      gap: clamp(16px, 2.4vw, 34px);
      font-weight: 700;
    }
    .nav-links a:hover { color: var(--blue); }
    .nav-ctas { display: flex; gap: 10px; }

    /* ── BUTTONS ── */
    .btn {
      display: inline-flex; align-items: center; justify-content: center;
      min-height: 42px; padding: 0 20px; border-radius: 8px; border: 1px solid transparent;
      color: #fff; font-weight: 800; font-family: inherit; font-size: 0.95rem;
      background: linear-gradient(180deg, var(--blue), var(--blue-2));
      box-shadow: 0 14px 30px rgba(36,120,255,0.25);
      cursor: pointer; white-space: nowrap; transition: opacity 0.15s;
    }
    .btn:hover { opacity: 0.88; }
    .btn.outline {
      background: rgba(2,9,19,0.45);
      border-color: rgba(255,255,255,0.55);
      box-shadow: none;
    }
    .btn.lg { min-height: 54px; padding: 0 32px; font-size: 1.05rem; }
    .btn.ghost { background: rgba(134,188,255,0.08); border-color: rgba(134,188,255,0.22); box-shadow: none; }

    /* ── HERO ── */
    .hero {
      width: min(100% - 40px, 1220px);
      margin: auto;
      padding: 90px 0 80px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      align-items: center;
    }
    .hero-eyebrow {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 5px 12px; border-radius: 999px;
      border: 1px solid rgba(87,217,128,0.38);
      background: rgba(87,217,128,0.1);
      color: var(--green);
      font-size: 0.82rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.06em;
      margin-bottom: 22px;
    }
    .hero-eyebrow::before { content: "●"; font-size: 0.6rem; }
    .hero h1 {
      font-size: clamp(2.4rem, 5vw, 3.8rem);
      font-weight: 900;
      line-height: 1.05;
      text-transform: uppercase;
      margin-bottom: 22px;
    }
    .hero h1 span { color: var(--blue); }
    .hero p {
      font-size: 1.1rem;
      color: var(--muted);
      line-height: 1.65;
      max-width: 480px;
      margin-bottom: 36px;
    }
    .hero-actions { display: flex; gap: 14px; flex-wrap: wrap; }
    .hero-stats {
      display: flex; gap: 28px; margin-top: 40px;
      padding-top: 28px; border-top: 1px solid rgba(134,188,255,0.18);
    }
    .hero-stat strong { display: block; font-size: 2rem; font-weight: 900; color: #fff; line-height: 1; }
    .hero-stat span { color: var(--muted); font-size: 0.85rem; font-weight: 700; }

    /* ── DASHBOARD PREVIEW ── */
    .dashboard-preview {
      border: 1px solid var(--line);
      border-radius: 16px;
      background: linear-gradient(145deg, rgba(22,58,98,0.38), rgba(3,13,27,0.92)), var(--panel);
      box-shadow: 0 40px 100px rgba(0,0,0,0.6), inset 0 1px 0 rgba(255,255,255,0.06);
      overflow: hidden;
    }
    .preview-bar {
      display: flex; align-items: center; gap: 8px;
      padding: 12px 16px;
      background: rgba(2,9,19,0.6);
      border-bottom: 1px solid rgba(134,188,255,0.12);
    }
    .preview-dot { width: 10px; height: 10px; border-radius: 50%; }
    .preview-dot.red   { background: #ff5f57; }
    .preview-dot.amber { background: #febc2e; }
    .preview-dot.green { background: #28c840; }
    .preview-title { margin-left: 8px; font-size: 0.8rem; font-weight: 700; color: var(--muted); }
    .preview-body { padding: 20px; display: grid; gap: 12px; }
    .preview-metrics { display: grid; grid-template-columns: repeat(4,1fr); gap: 8px; }
    .preview-metric {
      padding: 12px;
      border: 1px solid rgba(134,188,255,0.18);
      border-radius: 8px;
      background: rgba(2,9,19,0.5);
    }
    .preview-metric strong { display: block; font-size: 1.4rem; font-weight: 900; }
    .preview-metric span { font-size: 0.72rem; color: var(--muted); font-weight: 700; }
    .preview-row {
      display: flex; align-items: center; justify-content: space-between;
      padding: 10px 12px;
      border: 1px solid rgba(134,188,255,0.14);
      border-radius: 8px;
      background: rgba(2,9,19,0.4);
      font-size: 0.82rem;
    }
    .preview-row-label { color: var(--muted); }
    .preview-pill {
      padding: 3px 9px; border-radius: 999px; font-size: 0.72rem; font-weight: 800;
    }
    .preview-pill.green { background: rgba(87,217,128,0.18); color: var(--green); border: 1px solid rgba(87,217,128,0.3); }
    .preview-pill.blue  { background: rgba(36,120,255,0.18); color: #8fc2ff;      border: 1px solid rgba(36,120,255,0.3); }

    /* ── SECTION WRAPPER ── */
    .section { width: min(100% - 40px, 1220px); margin: auto; padding: 80px 0; }
    .section-label {
      text-transform: uppercase; letter-spacing: 0.08em; font-size: 0.82rem; font-weight: 800;
      color: var(--blue); margin-bottom: 12px;
    }
    .section-title {
      font-size: clamp(1.8rem, 3.5vw, 2.8rem);
      font-weight: 900;
      text-transform: uppercase;
      line-height: 1.08;
      margin-bottom: 16px;
    }
    .section-title span { color: var(--blue); }
    .section-sub { color: var(--muted); line-height: 1.65; max-width: 580px; font-size: 1.05rem; }
    .section-divider { border: 0; border-top: 1px solid rgba(134,188,255,0.14); margin: 0; }

    /* ── FEATURES ── */
    .features-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 18px; margin-top: 50px; }
    .feature-card {
      padding: 28px;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: linear-gradient(145deg, rgba(22,58,98,0.32), rgba(3,13,27,0.9)), var(--panel);
      box-shadow: var(--shadow);
      transition: border-color 0.18s, transform 0.18s;
    }
    .feature-card:hover { border-color: var(--blue); transform: translateY(-2px); }
    .feature-icon {
      width: 48px; height: 48px; border-radius: 12px;
      background: rgba(36,120,255,0.16);
      border: 1px solid rgba(36,120,255,0.3);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.4rem; margin-bottom: 18px;
    }
    .feature-card h3 { font-size: 1.05rem; font-weight: 900; text-transform: uppercase; margin-bottom: 10px; }
    .feature-card p { color: var(--muted); font-size: 0.93rem; line-height: 1.55; }

    /* ── HOW IT WORKS ── */
    .how-grid {
      display: grid;
      grid-template-columns: repeat(3,1fr);
      gap: 18px;
      margin-top: 50px;
      counter-reset: steps;
    }
    .how-card {
      position: relative;
      padding: 28px;
      border: 1px solid rgba(134,188,255,0.22);
      border-radius: 14px;
      background: linear-gradient(145deg, rgba(36,120,255,0.08), rgba(3,13,27,0.88)), var(--panel);
      counter-increment: steps;
    }
    .how-card::before {
      content: counter(steps, decimal-leading-zero);
      display: block;
      font-size: 2.6rem;
      font-weight: 900;
      color: rgba(36,120,255,0.3);
      line-height: 1;
      margin-bottom: 14px;
      letter-spacing: -0.02em;
    }
    .how-card h3 { font-size: 1rem; font-weight: 900; text-transform: uppercase; margin-bottom: 10px; }
    .how-card p { color: var(--muted); font-size: 0.9rem; line-height: 1.55; }

    /* ── PRICING ── */
    .pricing-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 18px; margin-top: 50px; }
    .pricing-card {
      padding: 32px;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: linear-gradient(145deg, rgba(22,58,98,0.32), rgba(3,13,27,0.9)), var(--panel);
      box-shadow: var(--shadow);
      display: flex; flex-direction: column; gap: 20px;
    }
    .pricing-card.featured {
      border-color: var(--blue);
      background: linear-gradient(145deg, rgba(36,120,255,0.22), rgba(3,13,27,0.96)), var(--panel);
      position: relative;
    }
    .pricing-badge {
      position: absolute; top: -14px; left: 50%; transform: translateX(-50%);
      padding: 4px 16px; border-radius: 999px;
      background: linear-gradient(90deg, var(--blue), var(--violet));
      font-size: 0.78rem; font-weight: 900; white-space: nowrap; text-transform: uppercase; letter-spacing: 0.05em;
    }
    .pricing-name { font-size: 0.85rem; font-weight: 800; text-transform: uppercase; color: var(--muted); letter-spacing: 0.06em; }
    .pricing-amount strong { font-size: 3rem; font-weight: 900; line-height: 1; }
    .pricing-amount span { color: var(--muted); font-size: 0.9rem; }
    .pricing-desc { color: var(--muted); font-size: 0.9rem; line-height: 1.5; }
    .pricing-features { display: grid; gap: 10px; }
    .pricing-feature {
      display: flex; align-items: flex-start; gap: 10px;
      font-size: 0.9rem; color: var(--muted); line-height: 1.4;
    }
    .pricing-feature::before { content: "✓"; color: var(--green); font-weight: 900; flex-shrink: 0; }
    .pricing-cta { margin-top: auto; }

    /* ── TESTIMONIALS ── */
    .testimonial-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 18px; margin-top: 50px; }
    .testimonial-card {
      padding: 28px;
      border: 1px solid rgba(134,188,255,0.18);
      border-radius: 14px;
      background: rgba(6,26,45,0.6);
    }
    .testimonial-quote { font-size: 0.95rem; color: var(--muted); line-height: 1.65; margin-bottom: 20px; font-style: italic; }
    .testimonial-author strong { display: block; font-size: 0.9rem; font-weight: 900; }
    .testimonial-author span { font-size: 0.82rem; color: var(--muted); }

    /* ── CTA BANNER ── */
    .cta-banner {
      margin: 0 auto 80px;
      width: min(100% - 40px, 1220px);
      padding: 60px 50px;
      border: 1px solid rgba(36,120,255,0.38);
      border-radius: 18px;
      background:
        radial-gradient(circle at 10% 50%, rgba(36,120,255,0.22), transparent 24rem),
        radial-gradient(circle at 88% 40%, rgba(150,99,255,0.16), transparent 22rem),
        linear-gradient(145deg, rgba(22,58,98,0.48), rgba(3,13,27,0.96)), var(--panel);
      text-align: center;
    }
    .cta-banner h2 { font-size: clamp(1.8rem, 3.5vw, 2.8rem); font-weight: 900; text-transform: uppercase; margin-bottom: 14px; }
    .cta-banner h2 span { color: var(--blue); }
    .cta-banner p { color: var(--muted); font-size: 1.05rem; max-width: 540px; margin: 0 auto 32px; line-height: 1.6; }
    .cta-banner-actions { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }

    /* ── FOOTER ── */
    footer {
      border-top: 1px solid rgba(100,164,255,0.12);
      background: rgba(2,9,19,0.96);
      padding: 40px 0;
    }
    .footer-inner {
      width: min(100% - 40px, 1220px);
      margin: auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
      flex-wrap: wrap;
    }
    .footer-links { display: flex; gap: 24px; flex-wrap: wrap; }
    .footer-links a { font-size: 0.88rem; color: var(--muted); font-weight: 700; }
    .footer-links a:hover { color: var(--blue); }
    .footer-copy { font-size: 0.82rem; color: var(--muted); }

    /* ── RESPONSIVE ── */
    @media (max-width: 1000px) {
      .hero { grid-template-columns: 1fr; padding: 60px 0; gap: 40px; }
      .dashboard-preview { display: none; }
      .features-grid, .how-grid, .pricing-grid, .testimonial-grid { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 640px) {
      .features-grid, .how-grid, .pricing-grid, .testimonial-grid { grid-template-columns: 1fr; }
      .nav-links { display: none; }
      .preview-metrics { grid-template-columns: repeat(2,1fr); }
    }
  </style>
</head>
